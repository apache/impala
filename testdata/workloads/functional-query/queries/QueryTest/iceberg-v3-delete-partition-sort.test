# Basic SORT BY (linear sort) - deletion vectors on a sorted table
CREATE TABLE ice_v3_dv_sorted (id int, score int, label string)
SORT BY (score)
STORED BY ICEBERG
TBLPROPERTIES ('format-version'='3');

