---- QUERY
# Correlated subquery with a LIMIT clause
select id from functional.alltypes t where id IN
    (select s.id from functional.alltypesagg s where s.int_col = t.int_col
   and s.id > 1000 order by id limit 1) order by id
---- RESULTS
