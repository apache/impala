====
---- QUERY
CREATE TABLE ice_v3_count (i int, s string)
STORED BY ICEBERG
TBLPROPERTIES ('format-version'='3');
---- RESULTS
'Table has been created.'
====
---- QUERY
INSERT INTO ice_v3_count VALUES (1, 'a'), (2, 'b'), (3, 'c');
INSERT INTO ice_v3_count VALUES (4, 'd'), (5, 'e'), (6, 'f');
====
---- QUERY
# Delete a row to create a Deletion Vector. Now we have two data files:
# one with a DV (3 rows, 1 deleted) and one without (3 rows).
DELETE FROM ice_v3_count WHERE i = 2;
---- RUNTIME_PROFILE
NumModifiedRows: 0
NumDeletedRows: 1
====
---- QUERY
# count(*) optimization should work: only scan the data file with the DV,
# not the one without (its count is derived from metadata).
select count(*) from ice_v3_count;
---- RESULTS
5
---- TYPES
BIGINT
---- RUNTIME_PROFILE
aggregation(SUM, NumRowGroups): 1
====
---- QUERY
select count(*), 42 from ice_v3_count;
---- RESULTS
5,42
---- TYPES
BIGINT,TINYINT
---- RUNTIME_PROFILE
aggregation(SUM, NumRowGroups): 1
====
---- QUERY
# IMPALA-14993: SELECT with only constants must not activate the optimization.
select 1 from ice_v3_count;
---- RESULTS
1
1
1
1
1
---- TYPES
TINYINT
====
---- QUERY
# IMPALA-14993: Column projection must scan all rows correctly.
select i from ice_v3_count order by i;
---- RESULTS
1
3
4
5
6
---- TYPES
INT
====
