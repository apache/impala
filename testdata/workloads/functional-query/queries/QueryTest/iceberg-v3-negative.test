====
---- QUERY
CREATE TABLE ice_v3 (i int, s string)
STORED BY ICEBERG
TBLPROPERTIES('format-version'='3');

INSERT INTO ice_v3 VALUES (1, 'impala');
INSERT INTO ice_v3 VALUES (2, 'iceberg');
INSERT INTO ice_v3 VALUES (3, 'spark');
====
---- QUERY
# The first snapshot has no deletion vectors.
SELECT *
FROM iceberg_v3_deletion_vectors FOR SYSTEM_VERSION AS OF 2700858159721908397;
---- RESULTS
1
2
3
4
5
---- TYPES
INT
====
---- QUERY
# Default values on nested struct fields are rejected when materialized.
# Table test_complex_default: nested field j.f1 has an int initial-default in metadata.
# Selecting j materializes the struct and its nested fields, so the scan should fail.
SELECT j FROM test_complex_default;
---- CATCH
Default values are not supported for nested fields
====
---- QUERY
# Selecting j.f1 materializes the nested field, so the scan should fail.
SELECT j.f1 FROM test_complex_default;
---- CATCH
Default values are not supported for nested fields
====
---- QUERY
# Default values on binary/fixed types are rejected when materialized.
# Table iceberg_v3_all_types: col_binary has a binary default in metadata.
# Selecting col_binary should fail during planning when the column is materialized.
SELECT col_binary FROM iceberg_v3_all_types;
---- CATCH
Default values are not supported for BINARY/FIXED types
====
---- QUERY
SELECT * FROM iceberg_v3_all_types;
---- CATCH
Default values are not supported for BINARY/FIXED types
====
---- QUERY
# Table test_complex_default: ts_tz is TIMESTAMPTZ with an initial-default in metadata.
# Materializing ts_tz is rejected until session-timezone display is implemented.
SELECT ts_tz FROM test_complex_default;
---- CATCH
Default values are not supported for TIMESTAMPTZ types
====
---- QUERY
# SELECT * materializes ts_tz, so timestamptz default rejection applies.
SELECT * FROM test_complex_default;
---- CATCH
Default values are not supported for TIMESTAMPTZ types
====
---- QUERY
# Test TIMESTAMP write-default rejection
# Table iceberg_v3_all_types has write-default for col_timestamp in metadata.
# INSERT omitting col_timestamp should fail during analysis with clear error message.
INSERT INTO iceberg_v3_all_types (id, col_boolean, col_int, col_bigint, col_float,
    col_double, col_decimal, col_string, col_date, col_binary)
VALUES (200, true, 1, 2, 3.14, 2.71, 100.50, 'test', CAST('2024-01-01' AS DATE),
    CAST(unhex('ABCD') AS BINARY));
---- CATCH
Iceberg write-default values for TIMESTAMP type are not supported
====
---- QUERY
# Test BINARY write-default rejection
# Table iceberg_v3_all_types has write-default for col_binary in metadata.
# INSERT omitting col_binary should fail during analysis with clear error message.
INSERT INTO iceberg_v3_all_types (id, col_boolean, col_int, col_bigint, col_float,
    col_double, col_decimal, col_string, col_date, col_timestamp)
VALUES (201, false, 10, 20, 1.5, 2.5, 50.25, 'binary_test', CAST('2024-06-15' AS DATE),
    CAST('2024-06-15 10:30:00' AS TIMESTAMP));
---- CATCH
Iceberg write-default values for BINARY/FIXED types are not supported
====
---- QUERY
# Iceberg format-version < 3: column DEFAULT on CREATE is rejected
CREATE TABLE iceberg_neg_fv2_create (i INT DEFAULT 1)
STORED AS ICEBERG TBLPROPERTIES ('format-version'='2');
---- CATCH
Column DEFAULT on Iceberg tables requires 'format-version' >= 3
====
---- QUERY
# Iceberg format-version < 3: ADD COLUMN ... DEFAULT is rejected
CREATE TABLE iceberg_neg_fv2_add (id INT) STORED AS ICEBERG TBLPROPERTIES ('format-version'='2');
ALTER TABLE iceberg_neg_fv2_add ADD COLUMN j INT DEFAULT 1;
---- CATCH
Adding column with DEFAULT on Iceberg tables requires 'format-version' >= 3
====
---- QUERY
# Iceberg format-version < 3: ALTER COLUMN SET DEFAULT is rejected
CREATE TABLE iceberg_neg_fv2_alter (id INT, j INT) STORED AS ICEBERG TBLPROPERTIES ('format-version'='2');
ALTER TABLE iceberg_neg_fv2_alter ALTER COLUMN j SET DEFAULT 99;
---- CATCH
ALTER COLUMN SET/DROP DEFAULT on Iceberg tables requires 'format-version' >= 3
====
---- QUERY
# Iceberg format-version < 3: ALTER COLUMN DROP DEFAULT is rejected
CREATE TABLE iceberg_neg_fv2_dropdef (id INT, j INT) STORED AS ICEBERG TBLPROPERTIES ('format-version'='2');
ALTER TABLE iceberg_neg_fv2_dropdef ALTER COLUMN j DROP DEFAULT;
---- CATCH
ALTER COLUMN SET/DROP DEFAULT on Iceberg tables requires 'format-version' >= 3
====
---- QUERY
# Iceberg v3 DDL: BINARY column default rejected at analysis (CREATE)
CREATE TABLE iceberg_neg_ddl_bin_create (
  id INT,
  b BINARY DEFAULT CAST(unhex('41') AS BINARY)
) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
---- CATCH
Default values are not supported for type: BINARY
====
---- QUERY
# Iceberg v3 DDL: BINARY column default rejected at analysis (ADD COLUMN)
CREATE TABLE iceberg_neg_unsup_bin (id INT) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
ALTER TABLE iceberg_neg_unsup_bin ADD COLUMN b BINARY DEFAULT CAST(unhex('41') AS BINARY);
---- CATCH
Default values are not supported for type: BINARY
====
---- QUERY
# Iceberg v3 DDL: TIMESTAMP column default rejected at analysis (CREATE)
CREATE TABLE iceberg_neg_ddl_ts_create (
  id INT,
  ts TIMESTAMP DEFAULT CAST('2024-01-01 00:00:00' AS TIMESTAMP)
) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
---- CATCH
Iceberg DDL default values for TIMESTAMP type are not supported
====
---- QUERY
# Iceberg v3 DDL: TIMESTAMP column default rejected at analysis (ADD COLUMN)
CREATE TABLE iceberg_neg_unsup_ts (id INT) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
ALTER TABLE iceberg_neg_unsup_ts ADD COLUMN ts TIMESTAMP DEFAULT CAST('2024-01-01 00:00:00' AS TIMESTAMP);
---- CATCH
Iceberg DDL default values for TIMESTAMP type are not supported
====
---- QUERY
# Iceberg v3 DDL: non-constant default on complex column rejected (CREATE TABLE)
CREATE TABLE iceberg_neg_ddl_complex (
  id INT,
  arr ARRAY<INT> DEFAULT `array`(1)
) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
---- CATCH
Only constant values are allowed for default values
====
---- QUERY
# ADD COLUMN with non-constant complex default
CREATE TABLE iceberg_neg_ddl (id INT) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
ALTER TABLE iceberg_neg_ddl ADD COLUMN m MAP<STRING,INT> DEFAULT `map`('a', 1);
---- CATCH
Only constant values are allowed for default values
====
---- QUERY
# ALTER COLUMN SET DEFAULT with a non-constant complex literal
CREATE TABLE iceberg_neg_ddl_alter (id INT, s STRING) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
ALTER TABLE iceberg_neg_ddl_alter ALTER COLUMN s SET DEFAULT `map`('k', 'v');
---- CATCH
Only constant values are allowed for default values
====
---- QUERY
# CHANGE COLUMN with DEFAULT is rejected (must use ALTER COLUMN SET DEFAULT instead)
CREATE TABLE iceberg_neg_change_col (id INT, d_col DATE) STORED AS ICEBERG TBLPROPERTIES ('format-version'='3');
ALTER TABLE iceberg_neg_change_col CHANGE COLUMN d_col d_col DATE DEFAULT CAST('2024-01-15' AS DATE);
---- CATCH
Unsupported column options in ALTER TABLE CHANGE COLUMN statement
====
---- QUERY
# CREATE TABLE with DEFAULT but without explicit format-version=3 is rejected
CREATE TABLE iceberg_neg_no_v3 (
  id INT,
  j INT DEFAULT 42
) STORED AS ICEBERG;
---- CATCH
Column DEFAULT on Iceberg tables requires 'format-version' >= 3
====
