# Create a partitioned Iceberg table using the data from the sample table
CREATE EXTERNAL TABLE partitioned_delete_parq
(
  index INT,
  date_col DATE,
  timestamp_col TIMESTAMP,
  string_col STRING,
  double_col DOUBLE,
  float_col FLOAT,
  decimal_col DECIMAL(9,3),
  smallint_col int,
  int_col INT,
  bigint_col BIGINT,
  boolean_col BOOLEAN
) PARTITIONED BY (str_col String, tinyint_col int) stored as iceberg tblproperties('format-version'='2', 'external.table.purge'='true');
INSERT INTO partitioned_delete_parq PARTITION (str_col, tinyint_col) SELECT index, date_col, timestamp_col, string_col, double_col, float_col, decimal_col, smallint_col, int_col, bigint_col, boolean_col, str_col, tinyint_col FROM delete_sample;
====
---- QUERY
# This delete means that a future query with partitioned_delete_parq will need to
# do an antijoin with the delete files.
delete from partitioned_delete_parq where index between 21 and 25;
====
---- QUERY
# Some threads in this statement will have no files to process, and they can hit
# the tuple cache even within a single run of the statement. This relies on the
# IcebergDeleteNode correctly notifying the builder when it hits the tuple cache.
# Otherwise, it will hang.
delete from partitioned_delete_parq where index = 1 or index = 5 and date_col = "1969-04-21";
====
---- QUERY
drop table partitioned_delete_parq;
drop table delete_sample;
====