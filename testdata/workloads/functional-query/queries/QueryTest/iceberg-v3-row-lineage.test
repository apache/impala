select i, coalesce(_file_row_id, ICEBERG__FIRST__ROW__ID + FILE__POSITION),
          coalesce(_file_last_updated_sequence_number, ICEBERG__DATA__SEQUENCE__NUMBER)
from iceberg_v3_row_lineage;
---- RESULTS
5,7,6
---- TYPES
INT,BIGINT,BIGINT
