MERGE INTO s16_target USING s16_source ON s16_target.i = s16_source.i
WHEN MATCHED THEN UPDATE SET s16_target.s = s16_source.s
WHEN NOT MATCHED THEN INSERT VALUES (s16_source.i, s16_source.s);
