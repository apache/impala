====
---- QUERY
# Verify the runtime filter table for TPCH-Q5 where some filters are ineffective.
# The query is modified to use a fix join order.
use tpch_parquet;
set runtime_filter_wait_time_ms=10000;
select STRAIGHT_JOIN
  n_name,
  sum(l_extendedprice * (1 - l_discount)) as revenue
from
  lineitem,
  orders,
  customer,
  supplier,
  nation,
  region
where
  c_custkey = o_custkey
  and l_orderkey = o_orderkey
  and l_suppkey = s_suppkey
  and c_nationkey = s_nationkey
  and s_nationkey = n_nationkey
  and n_regionkey = r_regionkey
  and r_name = 'ASIA'
  and o_orderdate >= '1994-01-01'
  and o_orderdate < '1995-01-01'
group by
  n_name
order by
  revenue desc
---- RESULTS
'INDONESIA',55502041.1697
'VIETNAM',55295086.9967
'CHINA',53724494.2566
'INDIA',52035512.0002
'JAPAN',45410175.6954
